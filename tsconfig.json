{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "rootDir": "./src",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["chrome"],
    "paths": {
      "@/*": ["src/*"]
    },
    "sourceMap": false,
    "removeComments": false,
    "strict": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["src/**/*"]
}
