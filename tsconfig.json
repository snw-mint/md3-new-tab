{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "rootDir": "./src",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "node",
    "sourceMap": false,
    "removeComments": false,
    "noEmitOnError": false,
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
